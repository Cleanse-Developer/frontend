# Dependencies
node_modules/

# Next.js build output
# NOTE: we commit the production .next build so the (small) EC2 box can run
# `next start` without building. Only the dev-server / cache / trace artifacts
# below are ignored.
.next/dev/
.next/cache/
.next/trace
.next/trace-build
.next/diagnostics/
.next/turbopack/
out/

# Production build
build/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# macOS
.DS_Store

# IDE
.vscode/
.idea/

/.next
